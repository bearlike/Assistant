# syntax=docker/dockerfile:1

# Dockerfile.api — Mewbo API with Gunicorn
ARG BASE_IMAGE="ghcr.io/bearlike/mewbo-base:latest"
FROM $BASE_IMAGE

ARG VERSION="0.0.10"

LABEL org.opencontainers.image.title="Mewbo API" \
      org.opencontainers.image.description="REST API for the Mewbo task-agent assistant" \
      org.opencontainers.image.source="https://github.com/bearlike/Assistant" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.vendor="Krishnakanth Alagiri" \
      org.opencontainers.image.licenses="MIT"

USER root
WORKDIR /app

# 0. Install git (if missing from base), GitHub CLI, and Docker CLI
#    gh  ref: https://github.com/cli/cli/blob/trunk/docs/install_linux.md
#    docker ref: https://docs.docker.com/engine/install/debian/
RUN apt-get update && apt-get install -y --no-install-recommends git wget \
    && mkdir -p -m 755 /etc/apt/keyrings \
    && wget -nv -O /etc/apt/keyrings/githubcli-archive-keyring.gpg \
        https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && curl -fsSL https://download.docker.com/linux/debian/gpg \
        -o /etc/apt/keyrings/docker.asc \
    && chmod a+r /etc/apt/keyrings/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian bookworm stable" \
        > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y --no-install-recommends gh docker-ce-cli \
    && rm -rf /var/lib/apt/lists/*

# 1. Copy only dependency metadata first (layer caching — survives source changes)
COPY pyproject.toml uv.lock ./
COPY packages/mewbo_core/pyproject.toml packages/mewbo_core/pyproject.toml
COPY packages/mewbo_tools/pyproject.toml packages/mewbo_tools/pyproject.toml
COPY packages/mewbo_graph/pyproject.toml packages/mewbo_graph/pyproject.toml
COPY apps/mewbo_api/pyproject.toml apps/mewbo_api/pyproject.toml

# 2. Copy source
COPY packages/ packages/
COPY apps/mewbo_api/ apps/mewbo_api/
COPY configs/ configs/

# 3. Entrypoint (runs runtime init.d scripts, then execs gunicorn)
COPY docker/entrypoint-api.sh /app/docker/entrypoint-api.sh
RUN chmod +x /app/docker/entrypoint-api.sh

# 4. Install with BuildKit cache mount (pip wheels survive rebuilds)
ARG WIKI_EXTRAS=0
RUN if ! command -v uv >/dev/null 2>&1; then pip install --no-cache-dir uv; fi
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system \
        -e packages/mewbo_core \
        -e packages/mewbo_tools \
        -e apps/mewbo_api \
        gunicorn
# Wiki extras: tree-sitter, rank-bm25, numpy — only baked in when WIKI_EXTRAS=1.
# The `mewbo-api[wiki]` extra forwards to the local `mewbo-graph` capability
# library (packages/mewbo_graph), which is NOT published to any index. uv has
# no source for a bare `mewbo-graph>=0.0.13` requirement, so we hand it the
# local editable explicitly — mirroring the core/tools/api installs above —
# and let that satisfy the [wiki] extra's transitive dependency.
RUN --mount=type=cache,target=/root/.cache/uv \
    if [ "$WIKI_EXTRAS" = "1" ]; then \
        uv pip install --system \
            -e "packages/mewbo_graph[treesitter,retrieval]" \
            -e "apps/mewbo_api[wiki]"; \
    fi

# Pin the tree-sitter parser cache to a fixed, shared path so the build (root)
# and the runtime (uid 1000) resolve the SAME directory — tree_sitter_language_pack
# honours XDG_CACHE_HOME. Without this, a build-time pre-warm under /root/.cache
# would be invisible to the runtime user's ~/.cache and re-downloaded at runtime.
ENV XDG_CACHE_HOME=/opt/mewbo-cache

# Pre-warm the tree-sitter parser bundle at BUILD time. The language pack (1.x)
# fetches a per-platform parser archive from a GitHub release on first use; a
# transient 504 there would otherwise abort a live indexing run. Baking the
# bundle into the image removes that runtime GitHub dependency entirely (it
# survives container restarts because it lives in the image layer, not a
# volume). One download warms every language — the archive is the whole pack.
# Best-effort: a transient blip at build time must not break the image; the
# runtime path retries (mewbo_graph/wiki/graph.py:_download_with_retry) as the
# safety net.
RUN if [ "$WIKI_EXTRAS" = "1" ]; then \
        mkdir -p /opt/mewbo-cache && \
        ( python -c "import tree_sitter_language_pack as t; t.download(['python','javascript','typescript','go','rust'])" \
          || echo 'WARN: tree-sitter parser pre-warm failed; runtime will retry-download on first index' ) && \
        chown -R 1000:1000 /opt/mewbo-cache; \
    fi

# Pre-create plan-mode scratch directory with correct ownership.
# Named volumes copy permissions from the image on first mount, so
# ``plans-data:/tmp/mewbo/plans`` inherits mewbo ownership
# instead of root:root. The entrypoint also fixes ownership at
# runtime for volumes that already exist (see entrypoint-api.sh).
RUN mkdir -p /tmp/mewbo/plans /tmp/mewbo/wiki/clones && chown -R 1000:1000 /tmp/mewbo

ENV MASTER_API_TOKEN='msk-strong-password' \
    API_PORT=5125 \
    CLAUDE_PLUGIN_ROOT=''

# Single worker (RunRegistry is in-memory), 8 HTTP threads, 5-min timeout.
# entrypoint-api.sh runs docker/init.d/*.sh scripts before exec'ing gunicorn.
ENTRYPOINT ["/app/docker/entrypoint-api.sh"]
