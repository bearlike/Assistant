# syntax=docker/dockerfile:1

# Dockerfile.base — Dev-equipped agent runtime for Mewbo
FROM python:3.11-bookworm

ARG VERSION="0.0.10"
ARG USERNAME=mewbo
ARG USER_UID=1000
ARG USER_GID=$USER_UID

LABEL org.opencontainers.image.title="Mewbo Base" \
      org.opencontainers.image.description="Dev-equipped agent runtime for the Mewbo assistant" \
      org.opencontainers.image.source="https://github.com/bearlike/Assistant" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.vendor="Krishnakanth Alagiri" \
      org.opencontainers.image.licenses="MIT"

# ---------- System packages ----------
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential curl wget git zsh sudo \
        jq ripgrep fd-find less vim \
        openssh-client ca-certificates gnupg \
    && rm -rf /var/lib/apt/lists/*

# ---------- Non-root user with sudo ----------
RUN groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID -m -s /usr/bin/zsh $USERNAME \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

# ---------- Oh My Zsh ----------
USER $USERNAME
RUN sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
USER root

# ---------- nvm + Node.js LTS ----------
ENV NVM_DIR=/home/$USERNAME/.nvm
RUN mkdir -p $NVM_DIR && chown $USERNAME:$USERNAME $NVM_DIR
USER $USERNAME
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash \
    && . "$NVM_DIR/nvm.sh" && nvm install --lts
USER root
# Expose node/npm/npx on the system PATH via a stable symlink so non-login
# processes (gunicorn, LSP servers, npx) see the nvm-installed runtime
# without having to source nvm.sh. `npm install -g` targets the nvm prefix,
# so new global binaries land in /opt/node/bin automatically.
RUN ln -sfn "$(ls -d $NVM_DIR/versions/node/*/ | head -1 | sed 's:/$::')" /opt/node
ENV PATH=/opt/node/bin:$PATH

# ---------- Playwright CLI + full Chromium ----------
# @playwright/cli (binary: ``playwright-cli``) — agent-oriented browser
# automation, surfaced via the ``playwright-cli`` skill. We install the *full*
# Chromium build (the default browser) so sites render with full fidelity —
# JavaScript execution, web fonts, the real Chrome engine in new-headless mode.
# ``--with-deps`` pulls the Debian libraries Chromium needs; it shells out to
# ``apt-get``, so the package lists (cleaned after the system-packages layer
# above) MUST be refreshed first in this same layer. The version is PINNED:
# ``@latest`` drifted to 0.1.14, whose negation-flag parser rejects
# ``--no-shell`` ("Unknown option: --shell") and broke the image build — so we
# pin and drop ``--no-shell`` (the headless shell ships alongside full Chromium;
# a few extra MB, but a deterministic build). Browsers land in a world-readable
# system path so the non-root runtime user (mewbo, UID 1000) can launch them;
# PLAYWRIGHT_BROWSERS_PATH is an ENV so it persists into derived images
# (Dockerfile.api) for install-time and runtime.
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
RUN apt-get update \
    && npm install -g @playwright/cli@0.1.14 \
    && playwright-cli install-browser --with-deps \
    && chmod -R a+rX /ms-playwright \
    && rm -rf /var/lib/apt/lists/* /root/.npm

# ---------- Python: uv + Mewbo core packages ----------
RUN pip install --no-cache-dir uv

WORKDIR /app
COPY . /app

RUN uv pip install --system \
        -e packages/mewbo_core \
        -e packages/mewbo_tools \
    && rm -rf /root/.cache/uv

# ---------- Runtime defaults ----------
ENV CACHE_DIR='/tmp/mewbo_cache' \
    DEFAULT_MODEL='gpt-5.2' \
    LOG_LEVEL=DEBUG \
    ENVMODE=dev \
    VERSION=${VERSION} \
    COLOREDLOGS_FIELD_STYLES='asctime=color=240;name=45,inverse' \
    COLOREDLOGS_LEVEL_STYLES='info=220;spam=22;debug=34;verbose=34;notice=220;warning=202;success=118,bold;error=124;critical=background=red' \
    COLOREDLOGS_LOG_FORMAT='%(asctime)s [%(name)s] %(levelname)s %(message)s'

USER $USERNAME
