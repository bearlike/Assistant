{
  "$schema": "https://thekrishna.in/Assistant/latest/app.schema.json",
  "runtime": {
    "envmode": "dev",
    "log_level": "DEBUG",
    "log_style": "",
    "cli_log_style": "dark",
    "preflight_enabled": false,
    "cache_dir": "",
    "session_dir": "",
    "config_dir": ""
  },
  "storage": {
    "driver": "json",
    "mongodb": {
      "uri": "mongodb://localhost:27017",
      "database": "mewbo"
    }
  },
  "llm": {
    "api_base": "",
    "api_key": "sk-ant-xxxxxxxx",
    "default_model": "anthropic/claude-sonnet-4-6",
    "action_plan_model": "",
    "tool_model": "",
    "reasoning_effort": "",
    "reasoning_effort_models": [],
    "fallback": {
      "enabled": false,
      "models": []
    }
  },
  "context": {
    "recent_event_limit": 8,
    "selection_threshold": 0.8,
    "selection_enabled": true,
    "context_selector_model": ""
  },
  "token_budget": {
    "default_context_window": 128000,
    "auto_compact_threshold": 0.8,
    "model_context_windows": {}
  },
  "compaction": {
    "caveman_mode": false
  },
  "reflection": {
    "enabled": true,
    "model": ""
  },
  "langfuse": {
    "enabled": false,
    "host": "https://langfuse.server.local",
    "public_key": "pk-lf-xxxxxxxxxxxxxxxx",
    "secret_key": "sk-lf-xxxxxxxxxxxxxxxx"
  },
  "home_assistant": {
    "enabled": false,
    "url": "http://homeassistant.local:8123",
    "token": "ha_token_here"
  },
  "permissions": {
    "policy_path": "",
    "approval_mode": "ask"
  },
  "cli": {
    "disable_textual": false,
    "approval_style": "inline"
  },
  "chat": {
    "port": 8501,
    "address": "127.0.0.1"
  },
  "api": {
    "master_token": "msk-strong-password"
  },
  "agent": {
    "enabled": true,
    "max_depth": 5,
    "max_concurrent": 20,
    "default_sub_model": "",
    "allowed_models": [],
    "sub_agent_max_steps": 10,
    "default_denied_tools": [],
    "edit_tool": "search_replace_block",
    "llm_call_timeout": 120.0,
    "llm_call_retries": 3,
    "retry": {
      "backoff_base": 1.0,
      "backoff_cap": 60.0,
      "retry_after_cap": 60.0,
      "turn_deadline": 240.0,
      "fallback_retries": 1,
      "circuit_breaker_threshold": 3,
      "circuit_breaker_cooldown": 30.0,
      "budget_capacity": 24.0,
      "doom_loop_threshold": 3
    },
    "web_ide": {
      "enabled": false,
      "image": "codercom/code-server:latest",
      "default_lifetime_hours": 1,
      "max_lifetime_hours": 8,
      "cpus": 1.0,
      "memory": "1g",
      "pids_limit": 512,
      "network": "mewbo-ide",
      "state_dir": "/tmp/mewbo-ide"
    }
  },
  "hooks": {
    "pre_tool_use": [],
    "post_tool_use": [],
    "on_session_start": [],
    "on_session_end": []
  },
  "plugins": {
    "enabled": true,
    "enabled_plugins": [],
    "marketplaces": ["anthropics/claude-plugins-official"],
    "install_path": ""
  },
  "channels": {
    "nextcloud-talk": {
      "enabled": false,
      "bot_secret": "shared-hmac-secret-from-occ-talk-bot-install",
      "nextcloud_url": "http://localhost:8180",
      "nextcloud_host_header": "",
      "allowed_backends": [],
      "trigger_keyword": "@Mewbo"
    },
    "email": {
      "enabled": false,
      "imap_host": "imap.example.com",
      "imap_port": 993,
      "imap_ssl": true,
      "smtp_host": "smtp.example.com",
      "smtp_port": 587,
      "smtp_starttls": true,
      "username": "mewbo@example.com",
      "password": "app-password-here",
      "from_address": "Mewbo <mewbo@example.com>",
      "mailbox": "INBOX",
      "poll_interval_seconds": 30,
      "allowed_senders": ["user@example.com"],
      "allowed_recipients": ["mewbo@example.com"]
    }
  },
  "wiki": {
    "enabled": false,
    "clone_dir": "",
    "indexing": {
      "default_depth": "comprehensive",
      "default_language": "en",
      "max_files": 10000,
      "max_file_size_kb": 512,
      "planner_model": "",
      "page_model": "",
      "max_parallel_pages": 5
    },
    "embedding": {
      "enabled": true,
      "model": "openai/text-embedding-3-small",
      "batch_size": 64,
      "dimensions": 1536
    },
    "qa": {
      "default_model": "",
      "retrieval_k": 6,
      "answer_ttl_days": 30
    },
    "memory": {
      "enabled": true,
      "model": "",
      "max_insight_chars": 200,
      "max_anchors": 8,
      "dedup_k": 5,
      "dedup_cosine": 0.6,
      "fuzzy_jaccard": 0.85,
      "fusion_w_ppr": 0.1,
      "hub_degree": 50,
      "expansion_hops": 1
    },
    "refresh": {
      "default_mode": "auto",
      "closure_max_depth": 4,
      "drift_keep": 0.90,
      "drift_invalidate": 0.75,
      "page_keep": 0.05,
      "page_edit": 0.35,
      "page_regen": 0.70,
      "new_page_min": 5,
      "require_scope_confirm": false
    },
    "grounder_paths": [".mewbo/wiki.json", ".devin/wiki.json"]
  },
  "projects": {}
}
