{
  "$schema": "https://thekrishna.in/Assistant/latest/app.schema.json",
  "runtime": {
    "envmode": "dev",
    "log_level": "DEBUG",
    "log_style": "",
    "cli_log_style": "dark",
    "preflight_enabled": false,
    "cache_dir": "",
    "session_dir": "",
    "config_dir": ""
  },
  "storage": {
    "driver": "json",
    "mongodb": {
      "uri": "mongodb://localhost:27017",
      "database": "meeseeks"
    }
  },
  "llm": {
    "api_base": "",
    "api_key": "sk-ant-xxxxxxxx",
    "default_model": "anthropic/claude-sonnet-4-6",
    "action_plan_model": "",
    "tool_model": "",
    "reasoning_effort": "",
    "reasoning_effort_models": []
  },
  "context": {
    "recent_event_limit": 8,
    "selection_threshold": 0.8,
    "selection_enabled": true,
    "context_selector_model": ""
  },
  "token_budget": {
    "default_context_window": 128000,
    "auto_compact_threshold": 0.8,
    "model_context_windows": {}
  },
  "compaction": {
    "caveman_mode": false
  },
  "reflection": {
    "enabled": true,
    "model": ""
  },
  "langfuse": {
    "enabled": false,
    "host": "https://langfuse.server.local",
    "public_key": "pk-lf-xxxxxxxxxxxxxxxx",
    "secret_key": "sk-lf-xxxxxxxxxxxxxxxx"
  },
  "home_assistant": {
    "enabled": false,
    "url": "http://homeassistant.local:8123",
    "token": "ha_token_here"
  },
  "permissions": {
    "policy_path": "",
    "approval_mode": "ask"
  },
  "cli": {
    "disable_textual": false,
    "approval_style": "inline"
  },
  "chat": {
    "port": 8501,
    "address": "127.0.0.1"
  },
  "api": {
    "master_token": "msk-strong-password"
  },
  "agent": {
    "enabled": true,
    "max_depth": 5,
    "max_concurrent": 20,
    "default_sub_model": "",
    "allowed_models": [],
    "sub_agent_max_steps": 10,
    "default_denied_tools": [],
    "edit_tool": "search_replace_block",
    "web_ide": {
      "enabled": false,
      "image": "codercom/code-server:latest",
      "default_lifetime_hours": 1,
      "max_lifetime_hours": 8,
      "cpus": 1.0,
      "memory": "1g",
      "pids_limit": 512,
      "network": "meeseeks-ide",
      "state_dir": "/tmp/meeseeks-ide"
    }
  },
  "hooks": {
    "pre_tool_use": [],
    "post_tool_use": [],
    "on_session_start": [],
    "on_session_end": []
  },
  "plugins": {
    "enabled": true,
    "enabled_plugins": [],
    "marketplaces": ["anthropics/claude-plugins-official"],
    "install_path": ""
  },
  "channels": {
    "nextcloud-talk": {
      "enabled": false,
      "bot_secret": "shared-hmac-secret-from-occ-talk-bot-install",
      "nextcloud_url": "http://localhost:8180",
      "nextcloud_host_header": "",
      "allowed_backends": [],
      "trigger_keyword": "@Meeseeks"
    },
    "email": {
      "enabled": false,
      "imap_host": "imap.example.com",
      "imap_port": 993,
      "imap_ssl": true,
      "smtp_host": "smtp.example.com",
      "smtp_port": 587,
      "smtp_starttls": true,
      "username": "meeseeks@example.com",
      "password": "app-password-here",
      "from_address": "Meeseeks <meeseeks@example.com>",
      "mailbox": "INBOX",
      "poll_interval_seconds": 30,
      "allowed_senders": ["user@example.com"],
      "allowed_recipients": ["meeseeks@example.com"]
    }
  },
  "projects": {}
}
