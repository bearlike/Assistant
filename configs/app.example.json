{
  "$schema": "https://thekrishna.in/Assistant/latest/app.schema.json",
  "runtime": {
    "envmode": "dev",
    "log_level": "DEBUG",
    "log_style": "",
    "cli_log_style": "dark",
    "preflight_enabled": false,
    "cache_dir": "",
    "session_dir": "",
    "config_dir": ""
  },
  "storage": {
    "driver": "json",
    "mongodb": {
      "uri": "mongodb://localhost:27017",
      "database": "meeseeks"
    }
  },
  "llm": {
    "api_base": "",
    "api_key": "sk-ant-xxxxxxxx",
    "default_model": "anthropic/claude-sonnet-4-6",
    "action_plan_model": "",
    "tool_model": "",
    "reasoning_effort": "",
    "reasoning_effort_models": []
  },
  "context": {
    "recent_event_limit": 8,
    "selection_threshold": 0.8,
    "selection_enabled": true,
    "context_selector_model": ""
  },
  "token_budget": {
    "default_context_window": 128000,
    "auto_compact_threshold": 0.8,
    "model_context_windows": {}
  },
  "reflection": {
    "enabled": true,
    "model": ""
  },
  "langfuse": {
    "enabled": false,
    "host": "https://langfuse.server.local",
    "public_key": "pk-lf-xxxxxxxxxxxxxxxx",
    "secret_key": "sk-lf-xxxxxxxxxxxxxxxx"
  },
  "home_assistant": {
    "enabled": false,
    "url": "http://homeassistant.local:8123",
    "token": "ha_token_here"
  },
  "permissions": {
    "policy_path": "",
    "approval_mode": "ask"
  },
  "cli": {
    "disable_textual": false,
    "approval_style": "inline"
  },
  "chat": {
    "port": 8501,
    "address": "127.0.0.1"
  },
  "api": {
    "master_token": "msk-strong-password"
  },
  "agent": {
    "enabled": true,
    "max_depth": 5,
    "max_concurrent": 20,
    "default_sub_model": "",
    "allowed_models": [],
    "sub_agent_max_steps": 10,
    "default_denied_tools": [],
    "edit_tool": "search_replace_block"
  },
  "hooks": {
    "pre_tool_use": [],
    "post_tool_use": [],
    "on_session_start": [],
    "on_session_end": []
  },
  "projects": {}
}
